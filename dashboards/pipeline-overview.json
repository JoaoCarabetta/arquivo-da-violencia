{
  "title": "Arquivo da Violência - Pipeline",
  "uid": "arquivo-pipeline",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["arquivo", "pipeline"],
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "stage",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "query": "label_values(pipeline_attempts_total, stage)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Worker Alive",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pipeline_worker_alive", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] }
        }
      }
    },
    {
      "id": 2,
      "title": "Cron Enabled",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pipeline_cron_enabled", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "orange" }, "1": { "text": "ON", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pipeline_queue_depth", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 50 }
          ] }
        }
      }
    },
    {
      "id": 4,
      "title": "Redis Connected",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "pipeline_redis_connected", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DISCONNECTED", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 10,
      "title": "Task Outcomes (last 24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_task_total[5m])) by (task, outcome)",
          "refId": "A",
          "legendFormat": "{{task}} / {{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 20,
      "title": "Task Duration p50 / p95 by task",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(pipeline_task_duration_seconds_bucket[10m])) by (task, le))",
          "refId": "p50",
          "legendFormat": "p50 {{task}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_task_duration_seconds_bucket[10m])) by (task, le))",
          "refId": "p95",
          "legendFormat": "p95 {{task}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 30,
      "title": "Success Rate by Stage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_attempts_total{outcome=\"success\"}[15m])) by (stage) / clamp_min(sum(rate(pipeline_attempts_total[15m])) by (stage), 1)",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "green", "value": 0.95 }
          ] }
        }
      }
    },
    {
      "id": 40,
      "title": "Failures by Reason",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(pipeline_attempts_total{outcome=\"failure\"}[$__range])) by (failure_reason)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "title": "Attempt Duration p95 by Stage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_attempt_duration_seconds_bucket[10m])) by (stage, le))",
          "refId": "A",
          "legendFormat": "p95 {{stage}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 60,
      "title": "Downloaded Content Size",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(pipeline_attempt_content_length_bytes_bucket{stage=\"download\"}[15m])) by (le))",
          "refId": "p50",
          "legendFormat": "p50 bytes"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_attempt_content_length_bytes_bucket{stage=\"download\"}[15m])) by (le))",
          "refId": "p95",
          "legendFormat": "p95 bytes"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
