    {
      "id": 21,
      "title": "Cron enabled",
      "description": "Whether the worker has cron jobs enabled (config flag).",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 24, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "textMode": "auto",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
