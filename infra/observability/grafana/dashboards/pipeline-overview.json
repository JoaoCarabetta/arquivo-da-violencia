              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Backlog: extraction",
      "description": "Sources waiting to be extracted.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
