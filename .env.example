# =============================================================================
# Arquivo da Violência - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# --- Pipeline scheduling -----------------------------------------------------
# MUST be "true" in production. Enables two crons on the worker:
#   :05 UTC — hourly city ingest (ingest_cities_hourly)
#   :35 UTC — hourly backlog processing (classify/download/extract/dedup)
ENABLE_CRON=true

# --- LLM (Gemini) ------------------------------------------------------------
GEMINI_API_KEY=
EXTRACTION_MODEL=gemini-2.5-flash
SELECTION_MODEL=gemini-2.5-flash-lite

# --- Google Maps Geocoding (optional) ----------------------------------------
# When set, the pipeline geocodes events (latitude/longitude/plus_code/place_id/
# formatted_address/location_precision/geocoding_*). When empty, geocoding is
# skipped and those fields stay NULL. Enable the Geocoding API on the key.
GOOGLE_MAPS_API_KEY=

# --- Infrastructure ----------------------------------------------------------
# Inside docker compose these point at the service names; defaults shown.
REDIS_URL=redis://redis:6379
POSTGRES_PASSWORD=change-me-in-production
# Production/staging (docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://arquivo:${POSTGRES_PASSWORD}@postgres:5432/arquivo_prod
# Dev (docker-compose.dev.yml):
# DATABASE_URL=postgresql+asyncpg://arquivo:arquivo_dev@postgres:5432/arquivo_dev
# Legacy SQLite (local tooling / migration source only):
# DATABASE_URL=sqlite+aiosqlite:///./instance/violence.db
DEBUG=false

# --- Auth --------------------------------------------------------------------
# Generate a stable secret once with: openssl rand -hex 32
# If this changes between restarts, all admin sessions are invalidated.
JWT_SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Telegram notifications (optional) ---------------------------------------
# When set, the API sends pipeline + worker-health alerts to this chat,
# including a "Worker Down" alert if the worker stops heartbeating.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- GitHub issue creation on failures (optional) ----------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
