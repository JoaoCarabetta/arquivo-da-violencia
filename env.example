# Arquivo da Violência - Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (required for all LLM calls)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# LLM Models (OpenRouter slugs "<vendor>/<model>", per-stage, validated by backend/eval/)
# Model used for extracting structured event data from news articles
EXTRACTION_MODEL=deepseek/deepseek-v4-flash
# Model used for headline classification (cheapest, 100% on both fixtures)
SELECTION_MODEL=openai/gpt-oss-120b
# Model used for the article-body content gate before extraction
CONTENT_GATE_MODEL=google/gemini-2.5-flash-lite
# Model used for dedup match/cluster decisions (only model at 100% exact partition)
DEDUP_MODEL=google/gemini-3.1-flash-lite
# Model used for multi-source enrichment synthesis
ENRICHMENT_MODEL=deepseek/deepseek-v4-flash

# Google Maps Geocoding API Key (optional)
# When set, the pipeline geocodes events (latitude/longitude/plus_code/place_id/etc).
# When empty, geocoding is skipped and those fields stay NULL.
# Get a key at https://console.cloud.google.com (enable the Geocoding API)
GOOGLE_MAPS_API_KEY=

# Enable hourly cron job for city ingestion
ENABLE_CRON=false

# Debug mode (set to true for development)
DEBUG=false

# Deployment environment: development | staging | production
# Staging/production require ENABLE_AUTH=true, a secure JWT_SECRET_KEY, and bcrypt admin password hashes.
ENVIRONMENT=development

# JWT Authentication (backend)
# Required in staging/production. Generate with: openssl rand -hex 32
ENABLE_AUTH=true
JWT_SECRET_KEY=
ADMIN_USERNAME=admin
# Bcrypt hash (NOT plaintext) in staging/production. Generate with:
# python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=
# Additional admin accounts (comma-separated username:bcrypt_hash pairs)
# ADMIN_USERS=editor:$2b$12$...,reviewer:$2b$12$...

# Telegram Notifications
# Create a bot via @BotFather and get the token
# Get your chat ID by messaging @userinfobot or @get_id_bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Optional: POST JSON alerts when scripts/check-pipeline-health.sh --notify fails
# PIPELINE_HEALTH_WEBHOOK_URL=https://your-cursor-automation-webhook

# Frontend Configuration
# Google Analytics (GA4) Measurement ID (optional)
# Get your measurement ID from https://analytics.google.com
VITE_GA_MEASUREMENT_ID=

# Site URL for SEO (Open Graph, canonical URLs, etc.)
VITE_SITE_URL=https://arquivodaviolencia.com.br

# MapLibre basemap style URL (optional)
# Carto Positron (default) is lighter/faster for zoom; OpenFreeMap Liberty has richer labels:
# VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty
